# Production template — copy to `backend/.env` on the machine (never commit real secrets).
# Postgres defaults below match `docker-compose.yml` (user `restaurant_pos`, db `restaurant_pos`).
# For a real deployment, change POSTGRES_PASSWORD in Docker and update DATABASE_URL to match.

DATABASE_URL=postgresql://restaurant_pos:password123@127.0.0.1:5432/restaurant_pos
SECRET_KEY=your_secret_key_change_in_production
PORT=5001

# Optional: logging (default INFO if unset)
# LOG_LEVEL=INFO

# Production: keep unset or 0 so error responses stay user-safe
# APP_DEBUG=0
